# Server-side only. Do not expose this to the browser.
REMOVE_BG_API_KEY=your_remove_bg_api_key_here

# Optional public label used in UI or future extensions.
NEXT_PUBLIC_APP_NAME=Image Background Remover

# Google OAuth (server-side only)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Session signing secret for auth cookie (use a long random string)
AUTH_SESSION_SECRET=replace_with_a_long_random_secret

# Optional: explicitly set site origin used for OAuth callback construction
# APP_BASE_URL=http://localhost:3000

# D1 is bound via Cloudflare binding name `DB` (not .env variable).
# Configure in wrangler.toml / Cloudflare Pages settings.
